# GoBot backend configuration

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# SQLite database for scrape jobs and results
SCRAPER_DATABASE_PATH=data/app.db

# Playwright scraper behavior
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=60000
SCRAPER_SCROLL_PAUSE_MS=2000
SCRAPER_MAX_SCROLL_ATTEMPTS=50

# Future AI integration placeholders
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
