# GoBot backend configuration

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# SQLite database for scrape jobs and results
SCRAPER_DATABASE_PATH=data/app.db

# Scrapling-based scraper behavior
SCRAPER_TIMEOUT_MS=60000
SCRAPER_VERIFY_TLS=false

